# ============================================================
# SPPS Mac OS Code Base — .gitignore
# ============================================================

# ── macOS system files ───────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ── Instruments / Xcode trace bundles ────────────────────────
# These are large binary profiling artifacts and not source code
*.trace/
*.trace
experiments/profile_fb.trace/
experiments/profile_louds.trace/
experiments/profile_louds_new.trace/
experiments/profile_pb.trace/
experiments/profile_spps.trace/

# ── Compiled binaries (no extension on macOS) ────────────────
experiments/block_a_correctness
experiments/block_b_linearity
experiments/block_c_benchmarks
experiments/block_d_louds
experiments/block_e_compression
experiments/block_f_tail_latency
experiments/block_g_downstream
experiments/block_h_worked_examples
experiments/profiler
experiments/profiler_isolated

# ── Object / dependency files ─────────────────────────────────
*.o
*.d
*.dSYM/
*.su
*.idb
*.pdb

# ── Large raw dataset files (hundreds of MB — GitHub limit) ─────
# These cannot be stored in git without LFS; regenerate from source
experiments/xmark.xml
experiments/sqlite3_ast.json

# ── Dataset symlink (replaced by the real file below) ────────────
experiments/real_ast_benchmark.txt

# ── SQLite amalgamation (vendored, not project source) ───────
experiments/sqlite3.c
experiments/sqlite3.h

# ── Protobuf / FlatBuffers generated files ───────────────────
# Included in repo for reproducibility (reviewer can compile without protoc/flatc)
# To regenerate: protoc --cpp_out=. tree.proto && flatc --cpp tree.fbs

# ── Editor / IDE files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ── Logs and temporary output snapshots ──────────────────────
# Keep curated outputs (block_*_output*.txt, SPPS_*.txt)
# Exclude any auto-generated scratch logs
*.log
/tmp/

# ── Build system artifacts ────────────────────────────────────
build/
dist/
out/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile.deps
